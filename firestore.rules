rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: patients
    // Fields: name, age, gender, district, createdAt
    //
    // Collection: assessments
    // Fields: patientId, chvId, type, result, confidence, symptoms, recommendation, district, timestamp
    //
    // Collection: alerts
    // Fields: district, type, message, count, timestamp, status
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "axoblade@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPatient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.age is number && data.age >= 0 && data.age < 150 &&
             data.district is string && data.district.size() > 0;
    }

    function isValidAssessment(data) {
      return data.patientId is string &&
             data.type in ['malaria_rdt', 'muac', 'symptom_triage'] &&
             data.result is string &&
             data.district is string;
    }

    // Rules
    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidPatient(request.resource.data);
      allow delete: if isAdmin();
    }

    match /assessments/{assessmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAssessment(request.resource.data);
      allow update: if isAuthenticated() && isValidAssessment(request.resource.data) && (request.resource.data.chvId == resource.data.chvId || isAdmin());
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
